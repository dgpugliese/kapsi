---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = "Kappa Alpha Psi® Fraternity, Inc. — Achievement in every field of human endeavor. Founded January 5, 1911 at Indiana University Bloomington.",
  image = "/og-image.jpg",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://kappaalphapsi1911.com');
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@kapsi1911" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>

  <body>
    <a href="#main" class="skip-link">Skip to main content</a>

    <!-- Top Bar -->
    <div class="top-bar">
      <div class="container">
        <span>ΚΑΨ &nbsp;·&nbsp; Founded January 5, 1911 &nbsp;·&nbsp; Indiana University Bloomington</span>
        <div class="top-bar-right">
          <a href="/contact/need-assistance">Need Assistance</a>
          <a href="/member-login" class="top-cta">Brothers Only Login</a>
        </div>
      </div>
    </div>

    <!-- Header -->
    <header class="site-header" id="site-header">
      <div class="container">
        <nav class="nav-main" aria-label="Main navigation">

          <a href="/" class="nav-logo" aria-label="Kappa Alpha Psi Home">
            <div class="nav-logo-mark" aria-hidden="true">ΚΑΨ</div>
            <div class="nav-logo-text">
              Kappa Alpha Psi®
              <span>Fraternity, Inc.</span>
            </div>
          </a>

          <ul class="nav-links" role="list">

            <li class="nav-item">
              <button aria-haspopup="true" aria-expanded="false">About Us <span class="chevron" aria-hidden="true">▾</span></button>
