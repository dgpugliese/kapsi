---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found — Kappa Alpha Psi® Fraternity, Inc.">
  <section class="section" style="min-height:60vh; display:flex; align-items:center;">
    <div class="container" style="text-align:center; max-width:600px; margin:0 auto;">
      <div style="font-size:6rem; font-weight:800; color:var(--crimson); line-height:1;">404</div>
      <h1 style="font-size:2rem; margin:16px 0;">Page Not Found</h1>
      <p style="color:var(--gray-600); font-size:1.05rem; line-height:1.8; margin-bottom:32px;">
        The page you're looking for doesn't exist or may have been moved.
        Let's get you back on track.
      </p>
      <div style="display:flex; gap:16px; justify-content:center; flex-wrap:wrap;">
        <a href="/" class="btn btn--primary">Go Home</a>
        <a href="/contact/need-assistance" class="btn btn--outline">Need Assistance?</a>
      </div>
    </div>
  </section>
</Layout>
