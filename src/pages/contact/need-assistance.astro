---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Need Assistance — Kappa Alpha Psi® Fraternity, Inc."
  description="Contact Kappa Alpha Psi® International Headquarters for assistance with fraternity matters."
>

  <section class="page-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">›</span>
        <span>Need Assistance</span>
      </nav>
      <h1>Need Assistance?</h1>
      <p>Our International Headquarters team is ready to help you.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="assist-layout">

        <!-- Form -->
        <div class="assist-form-wrap">
          <h2 style="font-size:1.5rem; margin-bottom:8px;">Send Us a Message</h2>
          <p style="color:var(--gray-600); margin-bottom:28px;">
            Please complete the form below and a member of our staff will respond within 2–3 business days.
          </p>

          <form
            name="need-assistance"
            method="POST"
            action="/contact/thank-you"
            data-netlify="true"
            class="assist-form"
          >
            <input type="hidden" name="form-name" value="need-assistance" />

            <div class="form-grid">
              <div class="form-group">
                <label class="form-label" for="first-name">First Name <span class="req">*</span></label>
                <input class="form-control" type="text" id="first-name" name="first-name" required />
              </div>
              <div class="form-group">
                <label class="form-label" for="last-name">Last Name <span class="req">*</span></label>
                <input class="form-control" type="text" id="last-name" name="last-name" required />
              </div>
            </div>

            <div class="form-group">
              <label class="form-label" for="email">Email Address <span class="req">*</span></label>
              <input class="form-control" type="email" id="email" name="email" required />
            </div>

            <div class="form-group">
              <label class="form-label" for="phone">Phone Number</label>
              <input class="form-control" type="tel" id="phone" name="phone" />
            </div>

            <div class="form-group">
              <label class="form-label" for="member-status">Member Status <span class="req">*</span></label>
              <select class="form-control" id="member-status" name="member-status" required>
                <option value="">— Select —</option>
                <option>Active Member</option>
                <option>Alumni Member</option>
                <option>Undergraduate Member</option>
                <option>Life Member</option>
                <option>Non-Member / General Public</option>
              </select>
            </div>

            <div class="form-group">
              <label class="form-label" for="subject">Subject <span class="req">*</span></label>
              <select class="form-control" id="subject" name="subject" required>
                <option value="">— Select a topic —</option>
                <option>Membership Inquiry</option>
                <option>Dues & Financial Records</option>
                <option>Chapter Information</option>
                <option>Grand Chapter Awards</option>
                <option>IHQ General Inquiry</option>
                <option>Media / Press</option>
                <option>Programs & Community Service</option>
                <option>Website Technical Issue</option>
                <option>Other</option>
              </select>
            </div>

            <div class="form-group">
              <label class="form-label" for="message">Message <span class="req">*</span></label>
              <textarea class="form-control" id="message" name="message" rows="6" required placeholder="Please describe how we can assist you..."></textarea>
            </div>

            <button type="submit" class="btn btn--primary" style="width:100%;">Submit Request</button>
          </form>
        </div>

        <!-- Sidebar info -->
        <aside class="assist-sidebar">
          <div class="info-card">
            <h3>International Headquarters</h3>
            <div class="info-block">
              <div class="info-icon">📍</div>
              <div>
                <strong>Address</strong><br />
                2322-24 North Broad Street<br />
                Philadelphia, PA 19132-4590
              </div>
            </div>
            <div class="info-block">
              <div class="info-icon">📞</div>
              <div>
                <strong>Phone</strong><br />
                <a href="tel:+12152287184">(215) 228-7184</a>
              </div>
            </div>
            <div class="info-block">
              <div class="info-icon">📠</div>
              <div>
                <strong>Fax</strong><br />
                (215) 228-7181
              </div>
            </div>
            <div class="info-block">
              <div class="info-icon">🕐</div>
              <div>
                <strong>Office Hours</strong><br />
                Monday – Friday<br />
                9:00 AM – 5:00 PM ET
              </div>
            </div>
          </div>

          <div class="info-card" style="margin-top:24px;">
            <h3>Quick Resources</h3>
            <ul class="quick-links">
              <li><a href="/chapter-locator">→ Find a Chapter Near You</a></li>
              <li><a href="/dues-life-membership">→ Dues & Life Membership</a></li>
              <li><a href="/member-login">→ Brothers Only Portal</a></li>
              <li><a href="/contact/speaker-request">→ Request a Speaker</a></li>
              <li><a href="/contact/plan-a-visit">→ Plan a Visit to IHQ</a></li>
            </ul>
          </div>
        </aside>

      </div>
    </div>
  </section>

</Layout>

<style>
.assist-layout {
  display: grid;
  grid-template-columns: 1fr 340px;
  gap: 48px;
  align-items: start;
}
.assist-form-wrap {
  background: var(--white);
  border: 1px solid var(--gray-200);
  border-radius: var(--radius-lg);
  padding: 40px;
}
.req { color: var(--crimson); }
.info-card {
  background: var(--cream);
  border-radius: var(--radius-lg);
  padding: 28px;
  border: 1px solid var(--cream-dark);
}
.info-card h3 {
  font-size: 1.1rem;
  color: var(--crimson);
  margin-bottom: 20px;
  padding-bottom: 10px;
  border-bottom: 2px solid var(--crimson);
  display: inline-block;
}
.info-block {
  display: flex;
  gap: 12px;
  margin-bottom: 16px;
  font-size: 0.9rem;
  line-height: 1.6;
}
.info-icon { font-size: 1.1rem; flex-shrink: 0; margin-top: 2px; }
.info-block a { color: var(--crimson); }
.quick-links li { margin-bottom: 10px; }
.quick-links a {
  color: var(--crimson);
  font-size: 0.9rem;
  font-weight: 600;
}
.quick-links a:hover { color: var(--crimson-light); }
@media (max-width: 900px) {
  .assist-layout { grid-template-columns: 1fr; }
}
</style>
