---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Grand Chapter Leadership — Kappa Alpha Psi® Fraternity, Inc.">

  <div class="page-hero">
    <div class="container">
      <h1>Grand Chapter Leadership</h1>
      <p>Elected officers and appointed leaders serving the global brotherhood</p>
    </div>
  </div>

  <nav class="breadcrumb" aria-label="Breadcrumb">
    <div class="container">
      <a href="/">Home</a> &rsaquo; Leadership &rsaquo; Grand Chapter Leadership
    </div>
  </nav>

  <!-- Grand Polemarch Feature -->
  <section class="section section--cream">
    <div class="container">
      <div style="max-width:800px; margin:0 auto; text-align:center;">
        <img src="/images/mcmickle.png" alt="Grand Polemarch Jimmy McMickle Sr." style="width:240px; height:auto; border-radius:var(--radius-xl); margin-bottom:1.5rem; box-shadow:var(--shadow-xl);" />
        <span class="badge badge--crimson" style="margin-bottom:1rem; display:inline-block;">35th Grand Polemarch</span>
        <h2 style="font-family:var(--font-serif); font-size:2.2rem; color:var(--crimson); margin-bottom:0.25rem;">Jimmy McMickle Sr.</h2>
        <p style="font-size:1.1rem; color:var(--gold); font-weight:700; margin-bottom:1.5rem;">Grand Polemarch</p>
        <div class="divider"></div>
        <p style="line-height:1.8; color:var(--text-light); margin-top:1.5rem;">
          Jimmy McMickle Sr. serves as the 35th Grand Polemarch of Kappa Alpha Psi® Fraternity, Inc. As the fraternity's chief executive officer, the Grand Polemarch presides over all Grand Chapter affairs, provides strategic direction for the international organization, and serves as the primary ambassador of the fraternity's mission and values to the broader community.
        </p>
      </div>
    </div>
  </section>

  <!-- Grand Chapter Officers -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Grand Chapter Officers</h2>
      <p class="section-subtitle">Elected officers of the International Fraternity</p>
      <div class="grid grid--2">

        <div class="person-card">
          <div class="person-card-img-placeholder" aria-hidden="true">RJ</div>
          <div class="person-card-body">
            <div class="person-card-name">Robert L. Jenkins, Jr., Esq.</div>
            <div class="person-card-title">Senior Grand Vice Polemarch</div>
          </div>
        </div>

        <div class="person-card">
          <div class="person-card-img-placeholder" aria-hidden="true">VM</div>
          <div class="person-card-body">
            <div class="person-card-name">Victor L. Mattison</div>
            <div class="person-card-title">Junior Grand Vice Polemarch</div>
          </div>
        </div>

        <div class="person-card">
          <div class="person-card-img-placeholder" aria-hidden="true">KK</div>
          <div class="person-card-body">
            <div class="person-card-name">Kevin D. Kyles</div>
            <div class="person-card-title">Grand Keeper of Records</div>
          </div>
        </div>

        <div class="person-card">
          <div class="person-card-img-placeholder" aria-hidden="true">RB</div>
          <div class="person-card-body">
            <div class="person-card-name">Rhen C. Bass, Sr., CPA</div>
            <div class="person-card-title">Grand Keeper of Exchequer</div>
          </div>
        </div>

        <div class="person-card">
          <div class="person-card-img-placeholder" aria-hidden="true">LR</div>
          <div class="person-card-body">
            <div class="person-card-name">Lorenza A. Russell, Jr.</div>
            <div class="person-card-title">Grand Strategus</div>
          </div>
        </div>

        <div class="person-card">
          <div class="person-card-img-placeholder" aria-hidden="true">JA</div>
          <div class="person-card-body">
            <div class="person-card-name">Justin I. Alexis</div>
            <div class="person-card-title">Grand Lieutenant Strategus</div>
          </div>
        </div>

        <div class="person-card">
          <div class="person-card-img-placeholder" aria-hidden="true">KS</div>
          <div class="person-card-body">
            <div class="person-card-name">Kevin P. Scott</div>
            <div class="person-card-title">Grand Historian</div>
          </div>
        </div>

        <div class="person-card">
          <div class="person-card-img-placeholder" aria-hidden="true">MB</div>
          <div class="person-card-body">
            <div class="person-card-name">Michael F. Brown</div>
            <div class="person-card-title">Grand Chapter Nominating Committee Chairman</div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Grand Board of Directors -->
  <section class="section section--cream">
    <div class="container">
      <h2 class="section-title">Grand Board of Directors</h2>

      <div style="display:grid; grid-template-columns:1fr 1fr; gap:2rem; margin-bottom:2rem;">
        <div>
          <h3 style="color:var(--crimson); font-family:var(--font-serif); margin-bottom:1rem; border-bottom:2px solid var(--gold); padding-bottom:0.5rem;">Alumni Members</h3>
          <div class="person-card" style="margin-bottom:1rem;">
            <div class="person-card-img-placeholder" aria-hidden="true">DB</div>
            <div class="person-card-body">
              <div class="person-card-name">Damon O. Barry, Esq.</div>
              <div class="person-card-title">Alumni Grand Board Member</div>
            </div>
          </div>
          <div class="person-card" style="margin-bottom:1rem;">
            <div class="person-card-img-placeholder" aria-hidden="true">LC</div>
            <div class="person-card-body">
              <div class="person-card-name">Dr. Leonard E. Clemons</div>
              <div class="person-card-title">Alumni Grand Board Member</div>
            </div>
          </div>
          <div class="person-card">
            <div class="person-card-img-placeholder" aria-hidden="true">JW</div>
            <div class="person-card-body">
              <div class="person-card-name">Jwyanza B. Watt</div>
              <div class="person-card-title">Alumni Grand Board Member</div>
            </div>
          </div>
        </div>

        <div>
          <h3 style="color:var(--crimson); font-family:var(--font-serif); margin-bottom:1rem; border-bottom:2px solid var(--gold); padding-bottom:0.5rem;">Undergraduate Members</h3>
          <div class="person-card" style="margin-bottom:1rem;">
            <div class="person-card-img-placeholder" aria-hidden="true">CM</div>
            <div class="person-card-body">
              <div class="person-card-name">Cameron D. Morgan</div>
              <div class="person-card-title">Undergraduate Grand Board Member</div>
            </div>
          </div>
          <div class="person-card" style="margin-bottom:1rem;">
            <div class="person-card-img-placeholder" aria-hidden="true">IR</div>
            <div class="person-card-body">
              <div class="person-card-name">Isaiah M. Robinson</div>
              <div class="person-card-title">Undergraduate Grand Board Member</div>
            </div>
          </div>
          <div class="person-card">
            <div class="person-card-img-placeholder" aria-hidden="true">JY</div>
            <div class="person-card-body">
              <div class="person-card-name">Jaden G. York</div>
              <div class="person-card-title">Undergraduate Grand Board Member</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Administrative Staff -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Administrative Staff</h2>
      <p class="section-subtitle">International Headquarters professional staff</p>

      <div class="table-responsive">
        <table>
          <thead>
            <tr>
              <th>Name</th>
              <th>Title</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>Craig C. Chisholm</strong></td>
              <td>Chief of Staff</td>
            </tr>
            <tr>
              <td><strong>Britton L. Smith</strong></td>
              <td>Deputy Chief of Staff</td>
            </tr>
            <tr>
              <td><strong>Charles E. Exum, Jr.</strong></td>
              <td>Chief Administrative Officer</td>
            </tr>
            <tr>
              <td><strong>Steven Chatman</strong></td>
              <td>National Director of Organizational Effectiveness</td>
            </tr>
            <tr>
              <td><strong>Donald L. Woolridge, Sr.</strong></td>
              <td>Liaison to Executive Committee &amp; IHQ</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Board Appointees -->
  <section class="section section--cream">
    <div class="container">
      <h2 class="section-title">Grand Board Appointees</h2>
      <div class="grid grid--2">
        <div class="card">
          <div class="card-body">
            <h3 class="card-title">Cleophus Thomas, Jr., Esq.</h3>
            <p class="card-text"><span class="badge badge--crimson">General Counsel</span></p>
            <p class="card-text">Serves as legal counsel to the Grand Chapter, providing guidance on all legal matters affecting the fraternity's operations, governance, and obligations.</p>
          </div>
        </div>
        <div class="card">
          <div class="card-body">
            <h3 class="card-title">Cleveland Ferguson III, Esq.</h3>
            <p class="card-text"><span class="badge badge--crimson">Journal Editor</span></p>
            <p class="card-text">Oversees the editorial direction and content of the <em>Kappa Alpha Psi® Journal</em>, the fraternity's official publication. Contact: <a href="mailto:cferguson@kappaalphapsi.com">cferguson@kappaalphapsi.com</a></p>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>
