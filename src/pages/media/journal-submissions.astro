---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Journal Submissions — Kappa Alpha Psi® Fraternity, Inc."
  description="Guidelines and submission form for the Kappa Alpha Psi® Journal."
>

  <section class="page-hero">
    <div class="container">
      <h1>Journal Submissions</h1>
      <p>Submit content for consideration in the Kappa Alpha Psi® Journal.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sub-layout">

        <div>
          <h2 style="font-size:1.75rem; margin-bottom:24px;">Submission Guidelines</h2>

          <div class="guidelines">
            <div class="guideline-item">
              <div class="g-num">1</div>
              <div>
                <strong>Eligibility</strong>
                <p>All financial members of Kappa Alpha Psi® Fraternity, Inc. are eligible to submit content. Submissions from advisors and program participants may also be considered.</p>
              </div>
            </div>
            <div class="guideline-item">
              <div class="g-num">2</div>
              <div>
                <strong>Content Types</strong>
                <p>We accept: feature articles, chapter spotlights, achievement announcements, program recaps, obituaries, letters to the editor, and photography.</p>
              </div>
            </div>
            <div class="guideline-item">
              <div class="g-num">3</div>
              <div>
                <strong>Length</strong>
                <p>Articles should be 300–1,200 words. Chapter spotlights: 150–400 words. Letters to the editor: 100–250 words.</p>
              </div>
            </div>
            <div class="guideline-item">
              <div class="g-num">4</div>
              <div>
                <strong>Photos</strong>
                <p>High-resolution photos (minimum 300 DPI, JPG or PNG) are strongly encouraged with all submissions. Include captions identifying all individuals.</p>
              </div>
            </div>
            <div class="guideline-item">
              <div class="g-num">5</div>
              <div>
                <strong>Deadlines</strong>
                <p>Spring/Summer issue: <strong>March 1</strong>. Fall/Winter issue: <strong>September 1</strong>. Late submissions will be considered for the following issue.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="assist-form-wrap">
          <h2 style="font-size:1.4rem; margin-bottom:20px;">Submit Your Content</h2>
          <form
            name="journal-submission"
            method="POST"
            action="/contact/thank-you"
            data-netlify="true"
          >
            <input type="hidden" name="form-name" value="journal-submission" />

            <div class="form-grid">
              <div class="form-group">
                <label class="form-label" for="first-name">First Name <span class="req">*</span></label>
                <input class="form-control" type="text" id="first-name" name="first-name" required />
              </div>
              <div class="form-group">
                <label class="form-label" for="last-name">Last Name <span class="req">*</span></label>
                <input class="form-control" type="text" id="last-name" name="last-name" required />
              </div>
            </div>

            <div class="form-group">
              <label class="form-label" for="email">Email Address <span class="req">*</span></label>
              <input class="form-control" type="email" id="email" name="email" required />
            </div>

            <div class="form-group">
              <label class="form-label" for="chapter">Chapter / Province</label>
              <input class="form-control" type="text" id="chapter" name="chapter" />
            </div>

            <div class="form-group">
              <label class="form-label" for="content-type">Content Type <span class="req">*</span></label>
              <select class="form-control" id="content-type" name="content-type" required>
                <option value="">— Select —</option>
                <option>Feature Article</option>
                <option>Chapter Spotlight</option>
                <option>Achievement Announcement</option>
                <option>Program Recap</option>
                <option>Obituary</option>
                <option>Letter to the Editor</option>
                <option>Photography</option>
                <option>Other</option>
              </select>
            </div>

            <div class="form-group">
              <label class="form-label" for="title">Submission Title <span class="req">*</span></label>
              <input class="form-control" type="text" id="title" name="title" required />
            </div>

            <div class="form-group">
              <label class="form-label" for="content">Content / Article Text <span class="req">*</span></label>
              <textarea class="form-control" id="content" name="content" rows="10" required placeholder="Paste your article text here..."></textarea>
            </div>

            <div class="form-group">
              <label class="form-label" for="notes">Additional Notes</label>
              <textarea class="form-control" id="notes" name="notes" rows="3" placeholder="Photo captions, special formatting requests, etc."></textarea>
            </div>

            <button type="submit" class="btn btn--primary" style="width:100%;">Submit for Review</button>
          </form>
        </div>

      </div>
    </div>
  </section>

</Layout>

<style>
.sub-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: start;
}
.guidelines { display: grid; gap: 24px; }
.guideline-item {
  display: flex;
  gap: 16px;
  align-items: flex-start;
}
.g-num {
  flex-shrink: 0;
  width: 32px;
  height: 32px;
  background: var(--crimson);
  color: var(--white);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 0.9rem;
}
.guideline-item strong { display: block; margin-bottom: 4px; }
.guideline-item p { font-size: 0.875rem; color: var(--gray-600); line-height: 1.6; }
.assist-form-wrap {
  background: var(--white);
  border: 1px solid var(--gray-200);
  border-radius: var(--radius-lg);
  padding: 36px;
}
.req { color: var(--crimson); }
@media (max-width: 900px) {
  .sub-layout { grid-template-columns: 1fr; }
}
</style>
