---
import Layout from '../../layouts/Layout.astro';

const albums = [
  { title: '114th Founders\' Day Celebrations', year: '2025', count: 48, icon: '🎉' },
  { title: '87th Grand Chapter Meeting — Houston', year: '2024', count: 124, icon: '🏛️' },
  { title: 'Guide Right Program Highlights', year: '2024', count: 36, icon: '🎯' },
  { title: 'Are You OK? National Tour', year: '2024', count: 52, icon: '💚' },
  { title: 'Room To Read Book Drives', year: '2024', count: 29, icon: '📚' },
  { title: '113th Founders\' Day Celebrations', year: '2024', count: 87, icon: '🎉' },
  { title: 'Learn 2 Live Youth Sessions', year: '2023', count: 41, icon: '⚖️' },
  { title: 'Kappa League Leadership Retreat', year: '2023', count: 33, icon: '⭐' },
  { title: 'IHQ Staff & Brotherhood', year: '2023', count: 18, icon: '🤝' },
];
---

<Layout
  title="Photo Album — Kappa Alpha Psi® Fraternity, Inc."
  description="Official photo gallery of Kappa Alpha Psi® Fraternity, Inc. events, programs, and community service."
>

  <section class="page-hero">
    <div class="container">
      <h1>Photo Album</h1>
      <p>Official photos from Kappa Alpha Psi® events, programs, and community service.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">

      <div class="callout" style="margin-bottom:40px;">
        <strong>Members:</strong> Higher-resolution photos and additional albums are available in the
        <a href="/member-login">Brothers Only portal</a>. Access requires a valid member login.
      </div>

      <h2 class="section-title" style="margin-bottom:32px;">Photo Albums</h2>

      <div class="album-grid">
        {albums.map(album => (
          <div class="album-card">
            <div class="album-thumb">
              <span class="album-icon">{album.icon}</span>
            </div>
            <div class="album-body">
              <div class="album-year">{album.year}</div>
              <h3 class="album-title">{album.title}</h3>
              <p class="album-count">{album.count} photos</p>
            </div>
          </div>
        ))}
      </div>

      <div style="text-align:center; margin-top:48px;">
        <p style="color:var(--gray-600); margin-bottom:16px;">
          To submit photos for inclusion in the official Kappa Alpha Psi® photo archive, please contact
          IHQ at <a href="tel:+12152287184">(215) 228-7184</a>.
        </p>
        <a href="/contact/need-assistance" class="btn btn--outline">Contact IHQ</a>
      </div>

    </div>
  </section>

</Layout>

<style>
.album-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}
.album-card {
  background: var(--white);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-md);
  cursor: pointer;
  transition: transform var(--transition), box-shadow var(--transition);
}
.album-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
}
.album-thumb {
  background: linear-gradient(135deg, var(--crimson), var(--crimson-dark));
  height: 160px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.album-icon { font-size: 3.5rem; }
.album-body { padding: 20px; }
.album-year {
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--crimson);
  margin-bottom: 4px;
}
.album-title {
  font-size: 1rem;
  font-weight: 700;
  margin-bottom: 4px;
  line-height: 1.3;
}
.album-count {
  font-size: 0.8rem;
  color: var(--gray-400);
}
@media (max-width: 1024px) {
  .album-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 640px) {
  .album-grid { grid-template-columns: 1fr; }
}
</style>
