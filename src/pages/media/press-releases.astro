---
import Layout from '../../layouts/Layout.astro';

const releases = [
  {
    date: 'January 5, 2025',
    title: 'Kappa Alpha Psi® Fraternity Celebrates 114th Founders\' Day Nationwide',
    id: 'pr-2025-001',
    excerpt: 'International Headquarters announces 114th anniversary celebrations and legacy programming.',
  },
  {
    date: 'December 10, 2024',
    title: 'Kappa Alpha Psi® Foundation Awards Year-End Scholarships Totaling $750,000',
    id: 'pr-2024-006',
    excerpt: 'The Kappa Alpha Psi® Foundation closes 2024 with its largest single-year scholarship distribution.',
  },
  {
    date: 'November 1, 2024',
    title: 'Are You OK? Campaign Launches National Black Men\'s Mental Health Awareness Month',
    id: 'pr-2024-005',
    excerpt: 'In partnership with Johnson & Johnson, Kappa Alpha Psi® announces expanded mental health outreach for Black men.',
  },
  {
    date: 'September 15, 2024',
    title: 'Room To Read Partnership Surpasses 32,000 Book Donations',
    id: 'pr-2024-004',
    excerpt: 'Fraternity announces record book donation milestone, bringing literacy resources to under-resourced schools nationwide.',
  },
  {
    date: 'July 10, 2024',
    title: 'Statement from Grand Polemarch McMikle Following 87th Grand Chapter Meeting',
    id: 'pr-2024-003',
    excerpt: 'Grand Polemarch Jimmy McMikle Sr. outlines the fraternity\'s strategic priorities for 2024–2026.',
  },
  {
    date: 'April 22, 2024',
    title: 'Learn 2 Live Program Achieves 70,000 Youth Training Milestone',
    id: 'pr-2024-002',
    excerpt: 'Kappa Alpha Psi® constitutional rights education program reaches new milestone in youth outreach.',
  },
  {
    date: 'January 5, 2024',
    title: 'Kappa Alpha Psi® Celebrates 113th Founders\' Day Across 700+ Chapters',
    id: 'pr-2024-001',
    excerpt: 'Chapters around the world mark the 113th anniversary of the fraternity\'s founding with service and celebration.',
  },
];
---

<Layout
  title="Press Releases — Kappa Alpha Psi® Fraternity, Inc."
  description="Official press releases and statements from Kappa Alpha Psi® Fraternity, Inc. International Headquarters."
>

  <section class="page-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">›</span>
        <span>Media</span>
        <span aria-hidden="true">›</span>
        <span>Press Releases</span>
      </nav>
      <h1>Press Releases</h1>
      <p>Official statements and announcements from Kappa Alpha Psi® International Headquarters.</p>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:900px;">

      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:40px; flex-wrap:wrap; gap:16px;">
        <h2 class="section-title" style="margin-bottom:0;">Official Releases</h2>
        <a href="/media/news" class="btn btn--outline">News Coverage</a>
      </div>

      <div class="pr-list">
        {releases.map(pr => (
          <article class="pr-item">
            <div class="pr-date">{pr.date}</div>
            <h3 class="pr-title">{pr.title}</h3>
            <p class="pr-excerpt">{pr.excerpt}</p>
            <div class="pr-id">Release #{pr.id}</div>
          </article>
        ))}
      </div>

      <!-- Media Contact -->
      <div class="callout" style="margin-top:56px;">
        <h3 style="font-size:1.1rem; margin-bottom:8px;">Press Contact</h3>
        <p style="color:var(--gray-800); font-size:0.95rem; line-height:1.7;">
          Journalists and media professionals may contact Kappa Alpha Psi® International Headquarters
          at <a href="tel:+12152287184">(215) 228-7184</a>. For digital press kits,
          high-resolution images, and official statements, please use our
          <a href="/contact/need-assistance">media inquiry form</a>.
        </p>
      </div>

    </div>
  </section>

</Layout>

<style>
.pr-list { display: grid; gap: 0; }
.pr-item {
  padding: 28px 0;
  border-bottom: 1px solid var(--gray-200);
}
.pr-item:first-child { padding-top: 0; }
.pr-date {
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--crimson);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 6px;
}
.pr-title {
  font-size: 1.1rem;
  font-weight: 700;
  margin-bottom: 8px;
  color: var(--black);
  line-height: 1.35;
}
.pr-excerpt {
  font-size: 0.875rem;
  color: var(--gray-600);
  line-height: 1.6;
  margin-bottom: 8px;
}
.pr-id {
  font-size: 0.75rem;
  color: var(--gray-400);
  font-style: italic;
}
</style>
