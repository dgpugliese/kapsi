---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Member Directory — Kappa Alpha Psi® Fraternity, Inc.">

<div class="page-hero">
  <div class="container">
    <h1>Member Directory</h1>
    <p>Search for brothers across all chapters and provinces</p>
  </div>
</div>

<nav class="breadcrumb" aria-label="Breadcrumb">
  <div class="container">
    <a href="/">Home</a> &rsaquo; Member Directory
  </div>
</nav>

<section class="section">
  <div class="container">
    <!-- Auth Gate -->
    <div id="auth-gate" style="text-align:center; padding:48px 0;">
      <img src="/images/kap-crest.png" alt="" width="56" height="62" style="margin-bottom:16px; opacity:0.3;" />
      <p style="color:var(--gray-400);">Checking authentication...</p>
    </div>

    <!-- Directory (hidden until auth) -->
    <div id="directory" style="display:none;">
      <!-- Search -->
      <div class="dir-search">
        <div class="dir-search-row">
          <div class="dir-search-field">
            <label for="search-name">Name</label>
            <input type="text" id="search-name" placeholder="Search by first or last name..." />
          </div>
          <div class="dir-search-field">
            <label for="search-chapter">Chapter</label>
            <select id="search-chapter">
              <option value="">All Chapters</option>
            </select>
          </div>
          <div class="dir-search-field">
            <label for="search-province">Province</label>
            <select id="search-province">
              <option value="">All Provinces</option>
            </select>
          </div>
          <button class="btn btn--primary dir-search-btn" id="search-btn">Search</button>
        </div>
      </div>

      <!-- Results -->
      <div class="dir-results-info" id="results-info"></div>
      <div class="dir-results" id="dir-results">
        <p style="text-align:center; color:var(--gray-400); padding:32px 0;">Use the search above to find brothers in the directory.</p>
      </div>
    </div>
  </div>
</section>

</Layout>

<script>
  import { supabase } from '../lib/supabase';

  const authGate = document.getElementById('auth-gate')!;
  const directory = document.getElementById('directory')!;

  const { data: { session } } = await supabase.auth.getSession();
  if (!session) {
    authGate.innerHTML = `
      <img src="/images/kap-crest.png" alt="" width="64" height="70" style="margin-bottom:20px;" />
      <h2 style="font-family:var(--font-serif); color:var(--crimson); margin-bottom:8px;">Brothers Only</h2>
      <p style="color:var(--gray-600); margin-bottom:24px;">The Member Directory is available to authenticated members only.</p>
      <a href="/member-login" class="btn btn--primary">Sign In to Access</a>
    `;
  } else {
    authGate.style.display = 'none';
    directory.style.display = 'block';

    // Load chapters and provinces for dropdowns
    const { data: chapters } = await supabase.from('chapters').select('id, name, designation').order('name');
    const { data: provinces } = await supabase.from('provinces').select('id, name').order('name');

    const chapterSelect = document.getElementById('search-chapter') as HTMLSelectElement;
    const provinceSelect = document.getElementById('search-province') as HTMLSelectElement;

    chapters?.forEach((ch: any) => {
      const opt = document.createElement('option');
      opt.value = ch.id;
      opt.textContent = `${ch.name} (${ch.designation})`;
      chapterSelect.appendChild(opt);
    });

    provinces?.forEach((p: any) => {
      const opt = document.createElement('option');
      opt.value = p.id;
      opt.textContent = p.name;
      provinceSelect.appendChild(opt);
    });

    // For the directory, we need a policy that allows members to search other members (limited fields)
    // Since our RLS only allows self-access, we'll show the current member's own info as a demo
    // In production, you'd create a view or RPC function for directory search

    const resultsEl = document.getElementById('dir-results')!;
    const resultsInfo = document.getElementById('results-info')!;

    document.getElementById('search-btn')?.addEventListener('click', async () => {
      const nameQuery = (document.getElementById('search-name') as HTMLInputElement).value.trim();
      resultsEl.innerHTML = '<p style="text-align:center; color:var(--gray-400); padding:32px 0;">Searching...</p>';

      // Demo: show current user's profile as a search result
      const { data: members } = await supabase
        .from('members')
        .select('first_name, last_name, city, state, member_status, photo_url, chapter:primary_chapter_id ( name, designation )')
        .eq('id', session!.user.id);

      if (members && members.length > 0) {
        resultsInfo.textContent = `${members.length} result${members.length !== 1 ? 's' : ''} found`;
        resultsEl.innerHTML = members.map((m: any) => {
          const ch = m.chapter as any;
          const initials = (m.first_name?.[0] ?? '') + (m.last_name?.[0] ?? '');
          const isFinancial = m.member_status === 'financial' || m.member_status === 'life_member';
          return `
            <div class="dir-card">
              <div class="dir-card-avatar">
                ${m.photo_url
                  ? `<img src="${m.photo_url}" alt="${m.first_name} ${m.last_name}" />`
                  : `<span>${initials}</span>`
                }
              </div>
              <div class="dir-card-info">
                <h3>${m.first_name} ${m.last_name}</h3>
                <p class="dir-card-chapter">${ch ? `${ch.name} (${ch.designation})` : '—'}</p>
                <p class="dir-card-location">${m.city ?? ''}${m.city && m.state ? ', ' : ''}${m.state ?? ''}</p>
              </div>
              <div class="dir-card-status">
                <span class="status-chip status-chip--${isFinancial ? 'completed' : 'pending'}">${isFinancial ? 'Financial' : 'Non-Financial'}</span>
              </div>
            </div>
          `;
        }).join('');
      } else {
        resultsInfo.textContent = '';
        resultsEl.innerHTML = '<p style="text-align:center; color:var(--gray-400); padding:32px 0;">No results found. Try adjusting your search criteria.</p>';
      }
    });
  }
</script>

<style>
/* Directory Search */
.dir-search {
  background: var(--white);
  border: 1px solid var(--gray-100);
  border-radius: var(--radius-xl);
  padding: 24px;
  margin-bottom: 24px;
  box-shadow: var(--shadow-sm);
}
.dir-search-row {
  display: grid;
  grid-template-columns: 2fr 1.5fr 1.5fr auto;
  gap: 14px;
  align-items: end;
}
.dir-search-field label {
  display: block;
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--gray-600);
  margin-bottom: 6px;
  font-family: var(--font-sans);
}
.dir-search-field input,
.dir-search-field select {
  width: 100%;
  padding: 10px 14px;
  border: 1px solid var(--gray-200);
  border-radius: var(--radius);
  font-size: 0.9rem;
  font-family: var(--font-sans);
  background: var(--gray-50);
  box-sizing: border-box;
  transition: border-color var(--transition);
}
.dir-search-field input:focus,
.dir-search-field select:focus {
  outline: none;
  border-color: var(--crimson);
  background: var(--white);
}
.dir-search-btn { min-height: 42px; white-space: nowrap; }

.dir-results-info {
  font-size: 0.82rem;
  color: var(--gray-400);
  margin-bottom: 16px;
  font-family: var(--font-sans);
}

/* Results Cards */
.dir-card {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 16px 20px;
  background: var(--white);
  border: 1px solid var(--gray-100);
  border-radius: var(--radius-lg);
  margin-bottom: 8px;
  transition: all var(--transition);
}
.dir-card:hover {
  border-color: var(--gray-200);
  box-shadow: var(--shadow-sm);
}
.dir-card-avatar {
  width: 52px; height: 52px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--crimson-dark), var(--crimson));
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}
.dir-card-avatar img { width: 100%; height: 100%; object-fit: cover; }
.dir-card-avatar span {
  font-family: var(--font-serif);
  font-size: 1rem; font-weight: 700; color: var(--white);
}
.dir-card-info { flex: 1; }
.dir-card-info h3 {
  font-family: var(--font-serif);
  font-size: 1.05rem;
  color: var(--gray-800);
  margin-bottom: 2px;
}
.dir-card-chapter {
  font-size: 0.82rem;
  color: var(--crimson);
  font-weight: 600;
}
.dir-card-location {
  font-size: 0.78rem;
  color: var(--gray-400);
}
.dir-card-status { flex-shrink: 0; }

/* Responsive */
@media (max-width: 768px) {
  .dir-search-row {
    grid-template-columns: 1fr;
  }
  .dir-card { flex-wrap: wrap; }
  .dir-card-status { width: 100%; }
}
</style>
