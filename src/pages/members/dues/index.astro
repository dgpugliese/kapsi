---
import Layout from '../../../layouts/Layout.astro';
import PortalShell from '../../../components/PortalShell.astro';
---

<Layout title="Pay Grand Chapter Dues — Kappa Alpha Psi®">
<PortalShell title="Pay Grand Chapter Dues" activePage="dues">

  <div class="dues-page" id="dues-page">
    <!-- Status Banner -->
    <div class="dues-status" id="dues-status">
      <div class="dues-status-icon" id="dues-status-icon"></div>
      <div class="dues-status-info">
        <div class="dues-status-label" id="dues-status-label">Loading...</div>
        <div class="dues-status-detail" id="dues-status-detail"></div>
      </div>
    </div>

    <!-- Dues Breakdown -->
    <div class="portal-section">
      <h2>Annual Dues Breakdown</h2>
      <div class="dues-breakdown">
        <div class="dues-line">
          <span>Grand Chapter Per Capita Assessment</span>
          <span class="dues-amount">$130.00</span>
        </div>
        <div class="dues-line">
          <span>Province Per Capita Assessment</span>
          <span class="dues-amount">$35.00</span>
        </div>
        <div class="dues-line">
          <span>Journal Subscription</span>
          <span class="dues-amount">$20.00</span>
        </div>
        <div class="dues-line">
          <span>Technology Fee</span>
          <span class="dues-amount">$15.00</span>
        </div>
        <div class="dues-line dues-line--total">
          <span>Total Annual Dues</span>
          <span class="dues-amount">$200.00</span>
        </div>
      </div>
    </div>

    <!-- Payment Form -->
    <div class="portal-section">
      <h2>Make a Payment</h2>
      <form id="payment-form" class="payment-form">
        <div class="payment-options">
          <label class="payment-option">
            <input type="radio" name="payment_type" value="annual_dues" checked />
            <div class="payment-option-card">
              <div class="payment-option-title">Annual Dues</div>
              <div class="payment-option-amount">$200.00</div>
              <div class="payment-option-desc">Standard annual per capita assessment</div>
            </div>
          </label>
          <label class="payment-option">
            <input type="radio" name="payment_type" value="subscribing_life" />
            <div class="payment-option-card">
              <div class="payment-option-title">Subscribing Life</div>
              <div class="payment-option-amount">$1,250.00</div>
              <div class="payment-option-desc">Installment plan — 4 payments of $1,250</div>
            </div>
          </label>
          <label class="payment-option">
            <input type="radio" name="payment_type" value="life_membership" />
            <div class="payment-option-card">
              <div class="payment-option-title">Life Membership</div>
              <div class="payment-option-amount">$3,500.00</div>
              <div class="payment-option-desc">One-time payment for lifetime financial status</div>
            </div>
          </label>
        </div>

        <div class="payment-card-section">
          <h3>Payment Details</h3>
          <div class="form-row">
            <div class="form-group">
              <label for="card-name">Name on Card</label>
              <input type="text" id="card-name" placeholder="Full name as shown on card" required />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="card-number">Card Number</label>
              <input type="text" id="card-number" placeholder="1234 5678 9012 3456" maxlength="19" required />
            </div>
          </div>
          <div class="form-row form-row--split">
            <div class="form-group">
              <label for="card-exp">Expiration</label>
              <input type="text" id="card-exp" placeholder="MM / YY" maxlength="7" required />
            </div>
            <div class="form-group">
              <label for="card-cvv">CVV</label>
              <input type="text" id="card-cvv" placeholder="123" maxlength="4" required />
            </div>
            <div class="form-group">
              <label for="card-zip">Billing ZIP</label>
              <input type="text" id="card-zip" placeholder="19132" maxlength="10" required />
            </div>
          </div>
        </div>

        <div class="payment-summary">
          <div class="payment-summary-line">
            <span>Payment Amount</span>
            <span id="payment-total" class="payment-summary-amount">$200.00</span>
          </div>
          <div class="payment-summary-line payment-summary-line--sub">
            <span>Fiscal Year</span>
            <span id="payment-fy">2026-2027</span>
          </div>
        </div>

        <button type="submit" class="btn btn--primary dues-submit-btn" id="submit-payment">
          <span id="pay-btn-text">Submit Payment — $200.00</span>
          <span id="pay-btn-loading" style="display:none;">Processing...</span>
        </button>

        <p class="payment-disclaimer">
          This is a demonstration portal. No actual payment will be processed.
          In production, this would integrate with a PCI-compliant payment processor.
        </p>
      </form>
    </div>

    <!-- Payment History -->
    <div class="portal-section">
      <h2>Payment History</h2>
      <div class="table-responsive">
        <table class="portal-table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Type</th>
              <th>Fiscal Year</th>
              <th>Amount</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody id="payments-body">
            <tr><td colspan="5" style="text-align:center; color:var(--gray-400);">Loading...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

</PortalShell>
</Layout>

<script>
  import { supabase } from '../../../lib/supabase';

  const { data: { session } } = await supabase.auth.getSession();
  if (!session) window.location.href = '/member-login';
  const userId = session!.user.id;

  // Fetch member + payments
  const { data: member } = await supabase.from('members').select('member_status, financial_through, life_member, first_name, last_name').eq('id', userId).single();
  const { data: payments } = await supabase.from('dues_payments').select('*').eq('member_id', userId).order('payment_date', { ascending: false });

  // Status banner
  const statusEl = document.getElementById('dues-status')!;
  const iconEl = document.getElementById('dues-status-icon')!;
  const labelEl = document.getElementById('dues-status-label')!;
  const detailEl = document.getElementById('dues-status-detail')!;

  if (member) {
    const isFinancial = member.member_status === 'financial' || member.member_status === 'life_member';
    statusEl.classList.add(isFinancial ? 'dues-status--good' : 'dues-status--warn');
    iconEl.innerHTML = isFinancial ? '&#10003;' : '&#9888;';
    labelEl.textContent = isFinancial ? 'You are currently financial' : 'You are not currently financial';
    if (member.financial_through) {
      detailEl.textContent = `Financial through ${new Date(member.financial_through).toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' })}`;
    }
    if (member.life_member) {
      detailEl.textContent = 'Life Member — No annual dues required';
    }

    // Pre-fill card name
    const cardName = document.getElementById('card-name') as HTMLInputElement;
    cardName.value = `${member.first_name} ${member.last_name}`;
  }

  // Payments table
  const pBody = document.getElementById('payments-body')!;
  if (payments && payments.length > 0) {
    pBody.innerHTML = payments.map((p: any) => `
      <tr>
        <td>${new Date(p.payment_date).toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' })}</td>
        <td>${p.payment_type.replace(/_/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase())}</td>
        <td>${p.fiscal_year ?? '—'}</td>
        <td>$${Number(p.amount).toFixed(2)}</td>
        <td><span class="status-chip status-chip--${p.status}">${p.status}</span></td>
      </tr>
    `).join('');
  } else {
    pBody.innerHTML = '<tr><td colspan="5" style="text-align:center; color:var(--gray-400);">No payment records found.</td></tr>';
  }

  // Payment option switching
  const amounts: Record<string, { amount: string; fy: string }> = {
    annual_dues: { amount: '$200.00', fy: '2026-2027' },
    subscribing_life: { amount: '$1,250.00', fy: '2026-2027 (1 of 4)' },
    life_membership: { amount: '$3,500.00', fy: 'N/A — Lifetime' },
  };

  document.querySelectorAll('input[name="payment_type"]').forEach(radio => {
    radio.addEventListener('change', () => {
      const val = (radio as HTMLInputElement).value;
      const info = amounts[val];
      document.getElementById('payment-total')!.textContent = info.amount;
      document.getElementById('payment-fy')!.textContent = info.fy;
      document.getElementById('pay-btn-text')!.textContent = `Submit Payment — ${info.amount}`;
    });
  });

  // Card number formatting
  document.getElementById('card-number')?.addEventListener('input', (e) => {
    const input = e.target as HTMLInputElement;
    input.value = input.value.replace(/\D/g, '').replace(/(\d{4})(?=\d)/g, '$1 ').substring(0, 19);
  });

  // Exp formatting
  document.getElementById('card-exp')?.addEventListener('input', (e) => {
    const input = e.target as HTMLInputElement;
    let v = input.value.replace(/\D/g, '');
    if (v.length >= 2) v = v.substring(0, 2) + ' / ' + v.substring(2, 4);
    input.value = v;
  });

  // Form submission (demo)
  document.getElementById('payment-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submit-payment') as HTMLButtonElement;
    const btnText = document.getElementById('pay-btn-text')!;
    const btnLoad = document.getElementById('pay-btn-loading')!;
    btn.disabled = true;
    btnText.style.display = 'none';
    btnLoad.style.display = 'inline';

    const selectedType = (document.querySelector('input[name="payment_type"]:checked') as HTMLInputElement).value;
    const amountMap: Record<string, number> = { annual_dues: 200, subscribing_life: 1250, life_membership: 3500 };
    const fyMap: Record<string, string> = { annual_dues: '2026-2027', subscribing_life: '2026-2027 (1 of 4)', life_membership: 'Lifetime' };

    // Insert payment record
    const { error } = await supabase.from('dues_payments').insert({
      member_id: userId,
      amount: amountMap[selectedType],
      payment_type: selectedType,
      fiscal_year: fyMap[selectedType],
      status: 'completed',
      notes: 'Online payment via member portal'
    });

    if (error) {
      alert('Payment failed: ' + error.message);
      btn.disabled = false;
      btnText.style.display = 'inline';
      btnLoad.style.display = 'none';
    } else {
      // Show success and reload
      btn.classList.add('dues-submit-btn--success');
      btnLoad.textContent = 'Payment Successful!';
      setTimeout(() => window.location.reload(), 1500);
    }
  });
</script>

<style>
/* Dues Status Banner */
.dues-status {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 20px 24px;
  border-radius: var(--radius-lg);
  margin-bottom: 32px;
  border: 1px solid var(--gray-100);
  background: var(--gray-50);
}
.dues-status--good {
  background: #ECFDF5;
  border-color: #A7F3D0;
}
.dues-status--warn {
  background: #FEF3C7;
  border-color: #FCD34D;
}
.dues-status-icon {
  width: 44px; height: 44px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.2rem;
  flex-shrink: 0;
}
.dues-status--good .dues-status-icon { background: #065F46; color: white; }
.dues-status--warn .dues-status-icon { background: #92400E; color: white; }
.dues-status-label {
  font-weight: 700;
  font-size: 1rem;
  color: var(--gray-800);
}
.dues-status-detail {
  font-size: 0.85rem;
  color: var(--gray-600);
  margin-top: 2px;
}

/* Dues Breakdown */
.dues-breakdown {
  border: 1px solid var(--gray-100);
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.dues-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 20px;
  font-size: 0.9rem;
  color: var(--gray-800);
  border-bottom: 1px solid var(--gray-50);
}
.dues-line:last-child { border-bottom: none; }
.dues-line--total {
  background: var(--crimson-dark);
  color: var(--white);
  font-weight: 700;
  font-size: 1rem;
}
.dues-line--total .dues-amount { color: var(--gold); font-size: 1.15rem; }
.dues-amount { font-weight: 600; font-family: var(--font-sans); }

/* Payment Options */
.payment-options {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
  margin-bottom: 28px;
}
.payment-option input { display: none; }
.payment-option-card {
  border: 2px solid var(--gray-200);
  border-radius: var(--radius-lg);
  padding: 20px;
  cursor: pointer;
  transition: all var(--transition);
  text-align: center;
}
.payment-option input:checked + .payment-option-card {
  border-color: var(--crimson);
  background: rgba(139,0,0,0.03);
  box-shadow: 0 0 0 1px var(--crimson);
}
.payment-option-card:hover {
  border-color: var(--gray-400);
}
.payment-option-title {
  font-weight: 700;
  font-size: 0.85rem;
  color: var(--gray-800);
  margin-bottom: 6px;
}
.payment-option-amount {
  font-family: var(--font-serif);
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--crimson);
  margin-bottom: 6px;
}
.payment-option-desc {
  font-size: 0.75rem;
  color: var(--gray-400);
  line-height: 1.4;
}

/* Payment Card Section */
.payment-card-section {
  background: var(--gray-50);
  border: 1px solid var(--gray-100);
  border-radius: var(--radius-lg);
  padding: 24px;
  margin-bottom: 24px;
}
.payment-card-section h3 {
  font-family: var(--font-serif);
  font-size: 1rem;
  color: var(--gray-800);
  margin-bottom: 16px;
}
.form-row { margin-bottom: 14px; }
.form-row:last-child { margin-bottom: 0; }
.form-row--split {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 12px;
}
.payment-form .form-group label {
  display: block;
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--gray-600);
  margin-bottom: 6px;
  font-family: var(--font-sans);
}
.payment-form .form-group input {
  width: 100%;
  padding: 10px 14px;
  border: 1px solid var(--gray-200);
  border-radius: var(--radius);
  font-size: 0.9rem;
  font-family: var(--font-sans);
  background: var(--white);
  box-sizing: border-box;
  transition: border-color var(--transition), box-shadow var(--transition);
}
.payment-form .form-group input:focus {
  outline: none;
  border-color: var(--crimson);
  box-shadow: 0 0 0 3px rgba(139,0,0,0.08);
}

/* Payment Summary */
.payment-summary {
  background: var(--cream);
  border: 1px solid var(--cream-dark);
  border-radius: var(--radius-lg);
  padding: 16px 20px;
  margin-bottom: 20px;
}
.payment-summary-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--gray-800);
}
.payment-summary-line--sub {
  font-size: 0.8rem;
  font-weight: 400;
  color: var(--gray-600);
  margin-top: 6px;
}
.payment-summary-amount {
  font-family: var(--font-serif);
  font-size: 1.3rem;
  font-weight: 700;
  color: var(--crimson);
}

/* Submit Button */
.dues-submit-btn {
  width: 100%;
  justify-content: center;
  padding: 16px;
  font-size: 1rem;
}
.dues-submit-btn:disabled { opacity: 0.7; cursor: not-allowed; }
.dues-submit-btn--success {
  background: #065F46 !important;
  border-color: #065F46 !important;
}

.payment-disclaimer {
  text-align: center;
  font-size: 0.75rem;
  color: var(--gray-400);
  margin-top: 16px;
  font-style: italic;
}

/* Responsive */
@media (max-width: 768px) {
  .payment-options { grid-template-columns: 1fr; }
  .form-row--split { grid-template-columns: 1fr 1fr; }
}
</style>
