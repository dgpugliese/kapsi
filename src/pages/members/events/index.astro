---
import Layout from '../../../layouts/Layout.astro';
import PortalShell from '../../../components/PortalShell.astro';
---

<Layout title="My Event Registrations — Kappa Alpha Psi®">
<PortalShell title="My Event Registrations" activePage="events">

  <div id="events-page">
    <!-- Upcoming Events -->
    <div class="portal-section">
      <h2>Upcoming Events</h2>
      <div id="upcoming-events">
        <p style="color:var(--gray-400); font-size:0.9rem;">Loading...</p>
      </div>
    </div>

    <!-- Past Events -->
    <div class="portal-section">
      <h2>All Registrations</h2>
      <div class="table-responsive">
        <table class="portal-table">
          <thead>
            <tr>
              <th>Event</th>
              <th>Date</th>
              <th>Location</th>
              <th>Registered</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody id="events-body">
            <tr><td colspan="5" style="text-align:center; color:var(--gray-400);">Loading...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

</PortalShell>
</Layout>

<script>
  import { supabase } from '../../../lib/supabase';

  const { data: { session } } = await supabase.auth.getSession();
  if (!session) window.location.href = '/member-login';

  const { data: events } = await supabase
    .from('event_registrations')
    .select('*')
    .eq('member_id', session!.user.id)
    .order('event_date', { ascending: true });

  const now = new Date();

  // Upcoming events cards
  const upcomingEl = document.getElementById('upcoming-events')!;
  const upcoming = events?.filter((e: any) => new Date(e.event_date) >= now) ?? [];

  if (upcoming.length > 0) {
    upcomingEl.innerHTML = `<div class="event-cards">${upcoming.map((ev: any) => `
      <div class="event-card-portal">
        <div class="event-card-date">
          <div class="event-card-month">${new Date(ev.event_date).toLocaleDateString('en-US', { month: 'short' })}</div>
          <div class="event-card-day">${new Date(ev.event_date).getDate()}</div>
          <div class="event-card-year">${new Date(ev.event_date).getFullYear()}</div>
        </div>
        <div class="event-card-info">
          <h3>${ev.event_name}</h3>
          <p>${ev.event_location ?? ''}</p>
          <span class="status-chip status-chip--${ev.status}">${ev.status}</span>
        </div>
      </div>
    `).join('')}</div>`;
  } else {
    upcomingEl.innerHTML = '<p style="color:var(--gray-400); font-size:0.9rem;">No upcoming events.</p>';
  }

  // All events table
  const eBody = document.getElementById('events-body')!;
  if (events && events.length > 0) {
    eBody.innerHTML = events.map((ev: any) => `
      <tr>
        <td><strong>${ev.event_name}</strong></td>
        <td>${ev.event_date ? new Date(ev.event_date).toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' }) : '—'}</td>
        <td>${ev.event_location ?? '—'}</td>
        <td>${new Date(ev.registration_date).toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' })}</td>
        <td><span class="status-chip status-chip--${ev.status}">${ev.status}</span></td>
      </tr>
    `).join('');
  } else {
    eBody.innerHTML = '<tr><td colspan="5" style="text-align:center; color:var(--gray-400);">No event registrations found.</td></tr>';
  }
</script>

<style>
.event-cards {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.event-card-portal {
  display: flex;
  gap: 20px;
  align-items: center;
  padding: 20px;
  border: 1px solid var(--gray-100);
  border-radius: var(--radius-lg);
  transition: all var(--transition);
}
.event-card-portal:hover {
  border-color: var(--gray-200);
  box-shadow: var(--shadow-sm);
}
.event-card-date {
  background: var(--crimson);
  color: var(--white);
  border-radius: var(--radius);
  padding: 12px 16px;
  text-align: center;
  min-width: 64px;
  flex-shrink: 0;
}
.event-card-month {
  font-size: 0.65rem;
  text-transform: uppercase;
  letter-spacing: 1px;
  font-weight: 600;
  opacity: 0.8;
}
.event-card-day {
  font-family: var(--font-serif);
  font-size: 1.6rem;
  font-weight: 700;
  line-height: 1.1;
}
.event-card-year {
  font-size: 0.65rem;
  opacity: 0.6;
}
.event-card-info h3 {
  font-family: var(--font-serif);
  font-size: 1.05rem;
  color: var(--gray-800);
  margin-bottom: 4px;
}
.event-card-info p {
  font-size: 0.82rem;
  color: var(--gray-600);
  margin-bottom: 8px;
}
</style>
