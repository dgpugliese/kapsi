---
import Layout from '../../layouts/Layout.astro';
import PortalShell from '../../components/PortalShell.astro';
---

<Layout title="My Info — Brothers Only — Kappa Alpha Psi® Fraternity, Inc.">
<PortalShell title="My Info" activePage="info">

  <Fragment slot="tabs">
    <button class="portal-tab active" data-tab="profile">Profile</button>
    <button class="portal-tab" data-tab="financial">Financial Status</button>
    <button class="portal-tab" data-tab="membership">Membership</button>
    <button class="portal-tab" data-tab="events">Events</button>
  </Fragment>

  <!-- Profile Tab -->
  <div class="portal-tab-content active" id="tab-profile">
    <div class="portal-section">
      <h2>Personal Information</h2>
      <div class="info-grid">
        <div class="info-item"><label>Full Name</label><span id="info-fullname">—</span></div>
        <div class="info-item"><label>Email</label><span id="info-email">—</span></div>
        <div class="info-item"><label>Phone</label><span id="info-phone">—</span></div>
        <div class="info-item"><label>Member Number</label><span id="info-member-number">—</span></div>
      </div>
    </div>
    <div class="portal-section">
      <h2>Address</h2>
      <div class="info-grid">
        <div class="info-item full"><label>Street Address</label><span id="info-address">—</span></div>
        <div class="info-item"><label>City</label><span id="info-city">—</span></div>
        <div class="info-item"><label>State</label><span id="info-state">—</span></div>
        <div class="info-item"><label>ZIP Code</label><span id="info-zip">—</span></div>
      </div>
    </div>
    <div class="portal-section">
      <h2>Professional</h2>
      <div class="info-grid">
        <div class="info-item"><label>Education</label><span id="info-education">—</span></div>
        <div class="info-item"><label>Occupation</label><span id="info-occupation">—</span></div>
        <div class="info-item"><label>Employer</label><span id="info-employer">—</span></div>
      </div>
    </div>
  </div>

  <!-- Financial Tab -->
  <div class="portal-tab-content" id="tab-financial">
    <div class="portal-section">
      <div class="financial-status-bar" id="financial-badge"></div>
      <div class="info-grid" style="margin-top:20px;">
        <div class="info-item"><label>Member Status</label><span id="fin-status">—</span></div>
        <div class="info-item"><label>Financial Through</label><span id="fin-through">—</span></div>
        <div class="info-item"><label>Life Member</label><span id="fin-life">—</span></div>
      </div>
    </div>
    <div class="portal-section">
      <h2>Payment History</h2>
      <div class="table-responsive">
        <table class="portal-table">
          <thead><tr><th>Date</th><th>Type</th><th>Fiscal Year</th><th>Amount</th><th>Status</th></tr></thead>
          <tbody id="payments-body"><tr><td colspan="5" style="text-align:center; color:var(--gray-400);">Loading...</td></tr></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Membership Tab -->
  <div class="portal-tab-content" id="tab-membership">
    <div class="portal-section">
      <h2>Membership Information</h2>
      <div class="info-grid">
        <div class="info-item"><label>Scrolling Number</label><span id="mem-scroll">—</span></div>
        <div class="info-item"><label>Member Number</label><span id="mem-number">—</span></div>
        <div class="info-item"><label>Initiated Date</label><span id="mem-initiated">—</span></div>
        <div class="info-item"><label>Chapter of Initiation</label><span id="mem-init-chapter">—</span></div>
      </div>
    </div>
    <div class="portal-section">
      <h2>Chapter Information</h2>
      <div class="info-grid">
        <div class="info-item"><label>Primary Chapter</label><span id="mem-chapter">—</span></div>
        <div class="info-item"><label>Chapter Type</label><span id="mem-chapter-type">—</span></div>
        <div class="info-item"><label>Province</label><span id="mem-province">—</span></div>
        <div class="info-item"><label>Location</label><span id="mem-chapter-location">—</span></div>
      </div>
    </div>
  </div>

  <!-- Events Tab -->
  <div class="portal-tab-content" id="tab-events">
    <div class="portal-section">
      <h2>My Event Registrations</h2>
      <div class="table-responsive">
        <table class="portal-table">
          <thead><tr><th>Event</th><th>Date</th><th>Location</th><th>Status</th></tr></thead>
          <tbody id="events-body"><tr><td colspan="4" style="text-align:center; color:var(--gray-400);">Loading...</td></tr></tbody>
        </table>
      </div>
    </div>
  </div>

</PortalShell>
</Layout>

<script>
  import { supabase } from '../../lib/supabase';

  const { data: { session } } = await supabase.auth.getSession();
  if (!session) window.location.href = '/member-login';
  const userId = session!.user.id;

  const { data: member } = await supabase
    .from('members')
    .select(`*, chapter:primary_chapter_id ( name, designation, chapter_type, city, state, university, province:province_id ( name, abbreviation ) )`)
    .eq('id', userId).single();

  const { data: payments } = await supabase.from('dues_payments').select('*').eq('member_id', userId).order('payment_date', { ascending: false });
  const { data: events } = await supabase.from('event_registrations').select('*').eq('member_id', userId).order('event_date', { ascending: true });

  if (member) {
    const fullName = [member.first_name, member.middle_name, member.last_name, member.suffix].filter(Boolean).join(' ');

    // Profile
    document.getElementById('info-fullname')!.textContent = fullName;
    document.getElementById('info-email')!.textContent = member.email ?? '—';
    document.getElementById('info-phone')!.textContent = member.phone ?? '—';
    document.getElementById('info-member-number')!.textContent = member.member_number ?? '—';
    document.getElementById('info-address')!.textContent = [member.address_line1, member.address_line2].filter(Boolean).join(', ') || '—';
    document.getElementById('info-city')!.textContent = member.city ?? '—';
    document.getElementById('info-state')!.textContent = member.state ?? '—';
    document.getElementById('info-zip')!.textContent = member.zip ?? '—';
    document.getElementById('info-education')!.textContent = member.education_level ?? '—';
    document.getElementById('info-occupation')!.textContent = member.occupation ?? '—';
    document.getElementById('info-employer')!.textContent = member.employer ?? '—';

    // Financial
    const isFinancial = member.member_status === 'financial' || member.member_status === 'life_member';
    document.getElementById('financial-badge')!.innerHTML = `<span class="financial-badge ${isFinancial ? 'financial-badge--good' : 'financial-badge--warn'}">${isFinancial ? 'FINANCIAL' : 'NON-FINANCIAL'}</span>`;
    document.getElementById('fin-status')!.textContent = member.member_status?.replace('_', ' ').replace(/\b\w/g, (c: string) => c.toUpperCase()) ?? '—';
    document.getElementById('fin-through')!.textContent = member.financial_through ? new Date(member.financial_through).toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' }) : '—';
    document.getElementById('fin-life')!.textContent = member.life_member ? 'Yes' : 'No';

    // Membership
    document.getElementById('mem-scroll')!.textContent = member.scrolling_number ?? '—';
    document.getElementById('mem-number')!.textContent = member.member_number ?? '—';
    document.getElementById('mem-initiated')!.textContent = member.initiated_date ? new Date(member.initiated_date).toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' }) : '—';
    document.getElementById('mem-init-chapter')!.textContent = member.chapter_of_initiation ?? '—';
    const ch = member.chapter as any;
    if (ch) {
      document.getElementById('mem-chapter')!.textContent = `${ch.name} (${ch.designation})`;
      document.getElementById('mem-chapter-type')!.textContent = ch.chapter_type === 'alumni' ? 'Alumni Chapter' : 'Undergraduate Chapter';
      document.getElementById('mem-province')!.textContent = ch.province?.name ?? '—';
      document.getElementById('mem-chapter-location')!.textContent = `${ch.city}, ${ch.state}`;
    }

    // Payments table
    const pBody = document.getElementById('payments-body')!;
    if (payments && payments.length > 0) {
      pBody.innerHTML = payments.map((p: any) => `<tr>
        <td data-label="Date">${new Date(p.payment_date).toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' })}</td>
        <td data-label="Type">${p.payment_type.replace(/_/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase())}</td>
        <td data-label="Fiscal Year">${p.fiscal_year ?? '—'}</td>
        <td data-label="Amount">$${Number(p.amount).toFixed(2)}</td>
        <td data-label="Status"><span class="status-chip status-chip--${p.status}">${p.status}</span></td>
      </tr>`).join('');
    } else {
      pBody.innerHTML = '<tr><td colspan="5" style="text-align:center; color:var(--gray-400);">No payment records found.</td></tr>';
    }

    // Events table
    const eBody = document.getElementById('events-body')!;
    if (events && events.length > 0) {
      eBody.innerHTML = events.map((ev: any) => `<tr>
        <td data-label="Event"><strong>${ev.event_name}</strong></td>
        <td data-label="Date">${ev.event_date ? new Date(ev.event_date).toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' }) : '—'}</td>
        <td data-label="Location">${ev.event_location ?? '—'}</td>
        <td data-label="Status"><span class="status-chip status-chip--${ev.status}">${ev.status}</span></td>
      </tr>`).join('');
    } else {
      eBody.innerHTML = '<tr><td colspan="4" style="text-align:center; color:var(--gray-400);">No event registrations found.</td></tr>';
    }
  }

  // Tabs
  document.querySelectorAll('.portal-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.portal-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.portal-tab-content').forEach(c => c.classList.remove('active'));
      tab.classList.add('active');
      document.getElementById(`tab-${(tab as HTMLElement).dataset.tab}`)?.classList.add('active');
    });
  });
</script>

<style>
.portal-tab-content { display: none; padding: 32px; }
.portal-tab-content.active { display: block; }
@media (max-width: 640px) {
  .portal-tab-content { padding: 20px 16px; }
}
</style>
