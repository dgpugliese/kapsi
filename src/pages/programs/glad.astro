---
import Layout from '../../layouts/Layout.astro';

const commitments = [
  "Champion financial literacy as a cornerstone of community empowerment and individual achievement",
  "Provide accessible, high-quality financial education resources to all members and their communities",
  "Partner with leading financial institutions and educational platforms to deliver best-in-class content",
  "Leverage the iGrad platform to deliver personalized, data-driven financial wellness programming",
  "Equip undergraduate members with the knowledge and skills to graduate debt-informed and financially prepared",
  "Support alumni members in achieving long-term financial goals including homeownership, retirement planning, and wealth building",
  "Advocate for systemic financial equity and access for communities of color across the United States",
  "Train chapter-level financial literacy ambassadors to multiply the program's impact in local communities",
  "Deliver targeted programming on student loan management, credit building, budgeting, and investing",
  "Measure and report on the program's financial literacy impact annually to the Grand Chapter",
  "Collaborate with Guide Right and Kappa League to extend financial literacy programming to youth",
  "Promote entrepreneurship and business ownership as pathways to financial independence and generational wealth"
];
---

<Layout title="G.L.A.D. — Kappa Alpha Psi® Fraternity, Inc.">

  <div class="page-hero">
    <div class="container">
      <h1>G.L.A.D.</h1>
      <p>Greeks Learning to Avoid Debt &mdash; Empowering Tomorrow's Leaders Through Financial Literacy</p>
    </div>
  </div>

  <!-- Chairman & Vision -->
  <section class="section section--cream">
    <div class="container">
      <div style="max-width:800px; margin:0 auto;">
        <div style="display:flex; align-items:center; gap:2rem; flex-wrap:wrap; margin-bottom:2rem; background:#fff; padding:2rem; border-radius:12px; box-shadow:0 4px 24px rgba(0,0,0,0.06);">
          <div style="width:80px; height:80px; background:var(--crimson); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:1.8rem; font-weight:700; color:#FFF8E1; flex-shrink:0;">JM</div>
          <div>
            <h2 style="font-family:var(--font-serif); color:var(--crimson); margin:0 0 0.25rem;">Jeffrey B. McGinnis</h2>
            <p style="color:var(--gold); font-weight:700; margin:0;">National Chairman, G.L.A.D.</p>
          </div>
        </div>

        <div class="callout callout--crimson">
          <p style="font-size:1.2rem; font-style:italic; font-weight:600; margin:0; text-align:center;">
            "Empowering Tomorrow's Leaders Through Financial Literacy"
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="section">
    <div class="container">
      <div style="max-width:800px; margin:0 auto;">
        <h2 class="section-title">About G.L.A.D.</h2>
        <div class="prose">
          <p><strong>G.L.A.D. — Greeks Learning to Avoid Debt</strong> — is Kappa Alpha Psi's national financial literacy initiative. Recognizing that financial vulnerability is one of the most significant barriers to achievement for communities of color, G.L.A.D. arms members with the knowledge, tools, and resources they need to achieve financial wellness and build lasting wealth.</p>
          <p>The program operates at both the individual and community level — providing financial education to fraternity members while also extending that knowledge outward through workshops, community events, and partnerships that reach beyond the brotherhood.</p>
          <p>G.L.A.D. leverages the <strong>iGrad platform</strong>, a leading financial wellness tool used by colleges and universities across the country, to deliver personalized, interactive financial literacy content to members wherever they are. The platform covers topics including budgeting, credit management, student loan repayment, investing, and retirement planning.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- iGrad -->
  <section class="section section--crimson">
    <div class="container">
      <div style="max-width:800px; margin:0 auto; text-align:center;">
        <h2 class="section-title" style="color:#FFF8E1;">The iGrad Platform</h2>
        <div style="background:rgba(255,255,255,0.1); border:1px solid rgba(201,168,76,0.4); border-radius:12px; padding:2rem;">
          <p style="color:rgba(255,248,225,0.9); line-height:1.8; margin-bottom:1.5rem;">
            G.L.A.D. partners with <strong style="color:var(--gold);">iGrad</strong>, an award-winning financial wellness platform used by hundreds of universities and organizations nationwide. Through the partnership, Kappa Alpha Psi® members gain access to:
          </p>
          <div class="grid grid--2" style="text-align:left;">
            <div style="background:rgba(255,255,255,0.08); border-radius:8px; padding:1.25rem;">
              <h4 style="color:var(--gold); margin-bottom:0.5rem;">Personalized Learning</h4>
              <p style="color:rgba(255,248,225,0.8); font-size:0.9rem; margin:0;">Customized financial education content based on each member's unique financial situation, goals, and learning pace.</p>
            </div>
            <div style="background:rgba(255,255,255,0.08); border-radius:8px; padding:1.25rem;">
              <h4 style="color:var(--gold); margin-bottom:0.5rem;">Comprehensive Coverage</h4>
              <p style="color:rgba(255,248,225,0.8); font-size:0.9rem; margin:0;">Topics spanning the full financial lifecycle: student loans, budgeting, credit, investing, insurance, homeownership, and retirement.</p>
            </div>
            <div style="background:rgba(255,255,255,0.08); border-radius:8px; padding:1.25rem;">
              <h4 style="color:var(--gold); margin-bottom:0.5rem;">Interactive Tools</h4>
              <p style="color:rgba(255,248,225,0.8); font-size:0.9rem; margin:0;">Calculators, quizzes, and planning tools that turn financial knowledge into actionable decisions.</p>
            </div>
            <div style="background:rgba(255,255,255,0.08); border-radius:8px; padding:1.25rem;">
              <h4 style="color:var(--gold); margin-bottom:0.5rem;">Progress Tracking</h4>
              <p style="color:rgba(255,248,225,0.8); font-size:0.9rem; margin:0;">Measurable milestones and progress reports that keep members accountable and motivated on their financial wellness journey.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 12 Commitments -->
  <section class="section section--cream">
    <div class="container">
      <div style="max-width:800px; margin:0 auto;">
        <h2 class="section-title">12 Organizational Commitments</h2>
        <p style="margin-bottom:2rem;">Kappa Alpha Psi® makes the following twelve commitments through the G.L.A.D. program:</p>
        <ol style="list-style:none; padding:0; counter-reset:commitments;">
          {commitments.map((commitment, i) => (
            <li style={`display:flex; align-items:flex-start; gap:1.25rem; padding:1rem 1.25rem; margin-bottom:0.75rem; background:#fff; border-radius:8px; border-left:4px solid ${i % 2 === 0 ? 'var(--crimson)' : 'var(--gold)'}; box-shadow:0 2px 8px rgba(0,0,0,0.05);`}>
              <span style="font-size:1.5rem; font-weight:800; color:var(--crimson); font-family:var(--font-serif); min-width:2rem; line-height:1;">{i + 1}</span>
              <p style="margin:0; line-height:1.6; color:var(--text-light);">{commitment}</p>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container" style="text-align:center;">
      <h2 class="section-title">Take Control of Your Financial Future</h2>
      <p style="color:var(--text-light); max-width:600px; margin:0 auto 2rem;">
        Financial literacy is not optional — it is the foundation of every other form of achievement. G.L.A.D. gives you the tools to build that foundation.
      </p>
      <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
        <a href="/member-login" class="btn btn--primary">Brothers Only Login</a>
        <a href="/contact/need-assistance" class="btn btn--outline">Get More Info</a>
      </div>
    </div>
  </section>

</Layout>
