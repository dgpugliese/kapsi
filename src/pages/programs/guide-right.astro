---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Guide Right — Kappa Alpha Psi® Fraternity, Inc.">

  <div class="page-hero">
    <div class="container">
      <h1>Guide Right</h1>
      <p>National Service Initiative &mdash; Mentoring Youth Toward Achievement</p>
    </div>
  </div>

  <nav class="breadcrumb" aria-label="Breadcrumb">
    <div class="container">
      <a href="/">Home</a> &rsaquo; <a href="/programs/guide-right">Programs</a> &rsaquo; Guide Right
    </div>
  </nav>

  <!-- Overview -->
  <section class="section section--cream">
    <div class="container">
      <div style="max-width:800px; margin:0 auto; text-align:center;">
        <h2 class="section-title">Our National Service Initiative</h2>
        <p style="font-size:1.1rem; line-height:1.8; color:var(--text-light);">
          Guide Right is our National Service Initiative and includes all youth oriented programs. The Flagship Initiative is the <strong>Kappa Leadership Development League</strong>, more commonly known as Kappa League.
        </p>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section section--crimson">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-item">
          <div class="stat-number">199</div>
          <div class="stat-label">Active Chapters</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">10,053</div>
          <div class="stat-label">Students Enrolled</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">500,000+</div>
          <div class="stat-label">Young People Mentored</div>
        </div>
      </div>
    </div>
  </section>

  <!-- History -->
  <section class="section">
    <div class="container">
      <div style="max-width:800px; margin:0 auto;">
        <h2 class="section-title">History of Guide Right</h2>
        <div class="prose">
          <p>The Guide Right program was conceived in 1922 by Brother <strong>Leon W. Stewart</strong>, who believed that the fraternity had a responsibility not just to its members, but to the young men who would one day seek to follow in their footsteps. Stewart's vision was that fraternity members — college-educated and professionally established — were uniquely positioned to guide the next generation.</p>
          <p>The program was formally adopted at the 12th Grand Chapter meeting, establishing it as an official fraternity-wide initiative. Since then, Guide Right has grown from a local mentoring concept into a comprehensive national service infrastructure that touches hundreds of thousands of young lives each year.</p>
          <p>The program's purpose is <strong>educational and occupational guidance of youth</strong> — primarily inspirational and informative in nature, connecting young men with the tools, knowledge, and mentors they need to achieve.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Objectives -->
  <section class="section section--cream">
    <div class="container">
      <div style="max-width:800px; margin:0 auto;">
        <h2 class="section-title">Five Objectives of Guide Right</h2>
        <div style="counter-reset:objectives;">
          <div class="icon-box" style="margin-bottom:1.25rem;">
            <div class="icon-box-icon" style="background:var(--crimson); color:#fff; min-width:44px; height:44px; display:flex; align-items:center; justify-content:center; border-radius:50%; font-weight:700; font-size:1.1rem;">1</div>
            <div class="icon-box-content">
              <h3 style="margin:0 0 0.25rem;">Inspire Academic Excellence</h3>
              <p style="margin:0; color:var(--text-light);">Motivate young men to pursue academic achievement and understand the connection between education and life success.</p>
            </div>
          </div>
          <div class="icon-box" style="margin-bottom:1.25rem;">
            <div class="icon-box-icon" style="background:var(--crimson); color:#fff; min-width:44px; height:44px; display:flex; align-items:center; justify-content:center; border-radius:50%; font-weight:700; font-size:1.1rem;">2</div>
            <div class="icon-box-content">
              <h3 style="margin:0 0 0.25rem;">Develop Leadership Skills</h3>
              <p style="margin:0; color:var(--text-light);">Provide structured opportunities for young men to develop and practice leadership skills in their schools, communities, and families.</p>
            </div>
          </div>
          <div class="icon-box" style="margin-bottom:1.25rem;">
            <div class="icon-box-icon" style="background:var(--crimson); color:#fff; min-width:44px; height:44px; display:flex; align-items:center; justify-content:center; border-radius:50%; font-weight:700; font-size:1.1rem;">3</div>
            <div class="icon-box-content">
              <h3 style="margin:0 0 0.25rem;">Provide Career Guidance</h3>
              <p style="margin:0; color:var(--text-light);">Connect youth with professional mentors and expose them to a wide range of career paths across every field of human endeavor.</p>
            </div>
          </div>
          <div class="icon-box" style="margin-bottom:1.25rem;">
            <div class="icon-box-icon" style="background:var(--crimson); color:#fff; min-width:44px; height:44px; display:flex; align-items:center; justify-content:center; border-radius:50%; font-weight:700; font-size:1.1rem;">4</div>
            <div class="icon-box-content">
              <h3 style="margin:0 0 0.25rem;">Foster Community Responsibility</h3>
              <p style="margin:0; color:var(--text-light);">Cultivate a sense of responsibility and civic engagement, encouraging young men to give back to their communities.</p>
            </div>
          </div>
          <div class="icon-box" style="margin-bottom:1.25rem;">
            <div class="icon-box-icon" style="background:var(--crimson); color:#fff; min-width:44px; height:44px; display:flex; align-items:center; justify-content:center; border-radius:50%; font-weight:700; font-size:1.1rem;">5</div>
            <div class="icon-box-content">
              <h3 style="margin:0 0 0.25rem;">Build Character and Integrity</h3>
              <p style="margin:0; color:var(--text-light);">Instill values of honesty, respect, personal integrity, and ethical conduct that will guide participants throughout their lives.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sub-programs CTA -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Guide Right Programs</h2>
      <div class="grid grid--2">
        <div class="card">
          <div class="card-body">
            <h3 class="card-title">Kappa League</h3>
            <p class="card-text">The flagship initiative of Guide Right — a structured mentoring program for male students in grades 6–12, providing leadership development, academic support, and career exposure.</p>
            <a href="/programs/kappa-league" class="btn btn--primary" style="margin-top:1rem; display:inline-block;">Learn More</a>
          </div>
        </div>
        <div class="card">
          <div class="card-body">
            <h3 class="card-title">Chapter Guide Right Programs</h3>
            <p class="card-text">Individual chapters across the country operate their own Guide Right activities including workshops, career days, college tours, tutoring programs, and community service projects.</p>
            <a href="/chapter-locator" class="btn btn--outline" style="margin-top:1rem; display:inline-block;">Find a Chapter</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Inquiry Form -->
  <section class="section section--cream">
    <div class="container">
      <div style="max-width:650px; margin:0 auto;">
        <h2 class="section-title">Guide Right Inquiry</h2>
        <p class="section-subtitle">Contact us to learn more or get involved with Guide Right in your area</p>

        <form method="POST" action="#" style="background:#fff; padding:2rem; border-radius:12px; box-shadow:0 4px 24px rgba(0,0,0,0.08);">
          <div class="form-group">
            <label class="form-label" for="gr-name">Full Name <span style="color:var(--crimson);">*</span></label>
            <input class="form-control" type="text" id="gr-name" name="name" required placeholder="Your Full Name" />
          </div>
          <div class="form-group">
            <label class="form-label" for="gr-email">Email Address <span style="color:var(--crimson);">*</span></label>
            <input class="form-control" type="email" id="gr-email" name="email" required placeholder="your@email.com" />
          </div>
          <div class="form-grid">
            <div class="form-group">
              <label class="form-label" for="gr-city">City</label>
              <input class="form-control" type="text" id="gr-city" name="city" placeholder="City" />
            </div>
            <div class="form-group">
              <label class="form-label" for="gr-state">State</label>
              <input class="form-control" type="text" id="gr-state" name="state" placeholder="State" />
            </div>
          </div>
          <div class="form-group">
            <label class="form-label" for="gr-message">Message</label>
            <textarea class="form-control" id="gr-message" name="message" rows="4" placeholder="How can we help you get involved with Guide Right?"></textarea>
          </div>
          <button type="submit" class="btn btn--primary" style="width:100%; margin-top:0.5rem;">Submit Inquiry</button>
        </form>
      </div>
    </div>
  </section>

</Layout>
