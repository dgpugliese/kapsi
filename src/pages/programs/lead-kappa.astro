---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Lead Kappa — Kappa Alpha Psi® Fraternity, Inc.">

  <div class="page-hero">
    <div class="container">
      <h1>Lead Kappa</h1>
      <p>Intensive Leadership Development at the Highest Level</p>
    </div>
  </div>

  <!-- Overview -->
  <section class="section section--cream">
    <div class="container">
      <div style="max-width:800px; margin:0 auto; text-align:center;">
        <h2 class="section-title">About Lead Kappa</h2>
        <div class="callout callout--crimson" style="text-align:left; margin-bottom:2rem;">
          <p style="font-size:1.15rem; line-height:1.8; margin:0;">
            "LEAD Kappa is a highly-structured and intense leadership experience held during the year of a conclave. It is designed to train participants with capacity building skills to lead in multiple contexts – in the fraternity, on college/university campus, in the community and in Corporate America."
          </p>
        </div>
        <p style="font-size:1rem; line-height:1.8; color:var(--text-light);">
          Lead Kappa represents the highest tier of leadership development programming offered by Kappa Alpha Psi® Fraternity, Inc. Unlike other programs, Lead Kappa is synchronized with the conclave cycle — occurring in the year that the Grand Chapter convenes — creating a unique convergence of organizational energy, alumni presence, and leadership focus.
        </p>
      </div>
    </div>
  </section>

  <!-- Four Contexts -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Four Leadership Contexts</h2>
      <p class="section-subtitle">Lead Kappa prepares participants to lead across all domains of life</p>
      <div class="grid grid--4">
        <div style="text-align:center; padding:2rem 1rem; background:var(--crimson); border-radius:12px; color:#FFF8E1;">
          <div style="font-size:2.5rem; margin-bottom:1rem;">ΚΑΨ</div>
          <h3 style="color:#FFF8E1; margin-bottom:0.5rem; font-size:1rem;">In the Fraternity</h3>
          <p style="color:rgba(255,248,225,0.8); font-size:0.9rem; margin:0;">Chapter leadership, Grand Board service, province roles, and contributions to the international fraternity's mission.</p>
        </div>
        <div style="text-align:center; padding:2rem 1rem; background:var(--gold); border-radius:12px; color:var(--crimson);">
          <div style="font-size:2.5rem; margin-bottom:1rem;">🎓</div>
          <h3 style="color:var(--crimson); margin-bottom:0.5rem; font-size:1rem;">On Campus</h3>
          <p style="color:rgba(139,0,0,0.8); font-size:0.9rem; margin:0;">Student government, academic organizations, multicultural leadership, and visible representation of Kappa excellence.</p>
        </div>
        <div style="text-align:center; padding:2rem 1rem; background:var(--cream); border-radius:12px; color:var(--crimson); border:2px solid var(--crimson);">
          <div style="font-size:2.5rem; margin-bottom:1rem;">🏘️</div>
          <h3 style="color:var(--crimson); margin-bottom:0.5rem; font-size:1rem;">In the Community</h3>
          <p style="color:var(--text-light); font-size:0.9rem; margin:0;">Civic engagement, nonprofit leadership, mentoring programs, and driving positive change in local communities.</p>
        </div>
        <div style="text-align:center; padding:2rem 1rem; background:#1a1a1a; border-radius:12px; color:#fff;">
          <div style="font-size:2.5rem; margin-bottom:1rem;">💼</div>
          <h3 style="color:var(--gold); margin-bottom:0.5rem; font-size:1rem;">In Corporate America</h3>
          <p style="color:rgba(255,255,255,0.7); font-size:0.9rem; margin:0;">Professional leadership, executive presence, entrepreneurship, and navigating the corporate landscape with integrity.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Capacity Building -->
  <section class="section section--cream">
    <div class="container">
      <div style="max-width:800px; margin:0 auto;">
        <h2 class="section-title">Capacity Building Skills</h2>
        <p style="margin-bottom:2rem;">Lead Kappa's curriculum is designed to build durable leadership capacity — skills and mindsets that participants can deploy throughout their careers and lives, not just during the program itself.</p>
        <div class="grid grid--2">
          <div class="icon-box">
            <div class="icon-box-icon">🧭</div>
            <div class="icon-box-content">
              <h3>Strategic Vision</h3>
              <p>The ability to see beyond immediate problems, set long-term direction, and inspire others to pursue a shared vision with commitment and energy.</p>
            </div>
          </div>
          <div class="icon-box">
            <div class="icon-box-icon">👥</div>
            <div class="icon-box-content">
              <h3>Team Building</h3>
              <p>Skills in assembling, motivating, and managing high-performing teams — and in maintaining team cohesion through challenge and change.</p>
            </div>
          </div>
          <div class="icon-box">
            <div class="icon-box-icon">📊</div>
            <div class="icon-box-content">
              <h3>Organizational Development</h3>
              <p>Understanding how organizations grow, adapt, and sustain themselves — and the leader's role in driving positive organizational change.</p>
            </div>
          </div>
          <div class="icon-box">
            <div class="icon-box-icon">🗺️</div>
            <div class="icon-box-content">
              <h3>Decision Making</h3>
              <p>Frameworks for making sound decisions under pressure, with limited information, and in ways that reflect the leader's values and the organization's mission.</p>
            </div>
          </div>
          <div class="icon-box">
            <div class="icon-box-icon">💬</div>
            <div class="icon-box-content">
              <h3>Executive Communication</h3>
              <p>High-level communication skills including public speaking, negotiation, media relations, and the ability to communicate with clarity and conviction at the highest levels.</p>
            </div>
          </div>
          <div class="icon-box">
            <div class="icon-box-icon">🔄</div>
            <div class="icon-box-content">
              <h3>Adaptive Leadership</h3>
              <p>The capacity to lead through ambiguity and change — recognizing when old approaches are failing and having the courage to chart a new course.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--crimson">
    <div class="container" style="text-align:center;">
      <h2 class="section-title" style="color:#FFF8E1;">Lead at the Highest Level</h2>
      <p style="color:rgba(255,248,225,0.85); max-width:600px; margin:0 auto 2rem;">
        Lead Kappa is held during the conclave year. Contact International Headquarters for information about eligibility, application, and upcoming program dates.
      </p>
      <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
        <a href="/contact/need-assistance" class="btn btn--white">Contact IHQ</a>
        <a href="/programs/undergraduate-leadership-institute" class="btn btn--outline-white">See Also: ULI</a>
      </div>
    </div>
  </section>

</Layout>
